# ── Contact Form Email Configuration ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# SMTP provider (use Resend, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxx

# Destination email for contact form submissions
CONTACT_DESTINATION_EMAIL=hello@flowtasker.com

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://flowtasker.com
