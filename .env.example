# ── Flowtasker — Variables d'environnement ────────────────────────────────────
# Copier ce fichier en .env.local et remplir les valeurs.
# NE JAMAIS committer .env.local ou tout fichier contenant de vraies clés.

# ── Site ──────────────────────────────────────────────────────────────────────
# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://flowtasker.com

# ── Contact Form — Email ──────────────────────────────────────────────────────
# Email de destination pour les soumissions du formulaire de contact
CONTACT_DESTINATION_EMAIL=hello@flowtasker.com

# Option 1 : Resend (recommandé — https://resend.com)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 : SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3 : Gmail (pour les tests uniquement)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votreadresse@gmail.com
# SMTP_PASS=votre_mot_de_passe_application
