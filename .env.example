# ── Flowtasker / Autom8Flow LLC — Variables d'environnement ──────────────────
# Copier ce fichier en .env.local et remplir les valeurs.
# NE JAMAIS committer .env.local

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://flowtasker.com

# ── Formulaire de contact ─────────────────────────────────────────────────────
CONTACT_DESTINATION_EMAIL=belabbar01@gmail.com

# ── SMTP — choisir un provider ────────────────────────────────────────────────
# Option 1 : Resend (recommandé — resend.com, gratuit jusqu'à 3000 emails/mois)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 : Gmail avec mot de passe d'application
# (Google Account → Sécurité → Mots de passe d'application)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=belabbar01@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Note phase de test : si SMTP non configuré, le formulaire retourne 200
# et un console.warn apparaît dans le terminal. Aucune erreur visible côté client.
